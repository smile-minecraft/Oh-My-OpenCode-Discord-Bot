# Project Hermes - Discord Bot Configuration
# Copy this file to .env and fill in your values

# ============================================
# Discord Bot Configuration
# ============================================

# Your Discord Bot Token (required)
# Get this from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application ID (required for slash commands)
DISCORD_APPLICATION_ID=your_application_id_here

# Guild ID for development/testing (optional, for faster command registration)
DISCORD_GUILD_ID=your_guild_id_here

# Channel ID where the bot will listen for commands and create threads
DISCORD_CHANNEL_ID=your_channel_id_here

# ============================================
# Oh My OpenCode Configuration
# ============================================

# Path to the Oh My OpenCode CLI executable
OMO_CLI_PATH=/usr/local/bin/omo

# Working directory for spawned CLI processes (optional, defaults to process.cwd())
OMO_WORKING_DIR=

# Environment variables to pass to spawned processes
# Format: KEY1=value1,KEY2=value2
OMO_ENV_VARS=

# Registered project paths for dropdown menu (comma-separated)
PROJECT_PATHS=/path/to/project1,/path/to/project2

# Button text sent to CLI stdin
APPROVE_TEXT=y
REJECT_TEXT=n

# Embed update configuration (ms)
EMBED_UPDATE_INTERVAL_MS=2000
MAX_EMBED_DESC_LENGTH=3800
MIN_EDIT_INTERVAL_MS=1000

# ============================================
# Bot Behavior Configuration
# ============================================

# Maximum character limit before flushing buffer to Discord (default: 1900)
# Discord has a 2000 character limit, we use 1900 to leave room for markdown
BUFFER_CHAR_LIMIT=1900

# Buffer flush interval in milliseconds (default: 500)
# How long to wait before flushing accumulated output
BUFFER_FLUSH_INTERVAL_MS=500

# Default auto-archive duration for threads in minutes
# Options: 60, 1440, 4320, 10080
THREAD_AUTO_ARCHIVE_DURATION=1440

# Maximum number of concurrent sessions (threads) per user
MAX_SESSIONS_PER_USER=3

# Log level: debug, info, warn, error
LOG_LEVEL=info
